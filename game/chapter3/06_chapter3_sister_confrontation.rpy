
label chapter3_sister_confrontation:

    scene kitchen_night_smoke
    'Сестра встаёт. Подходит ко мне. Садится рядом. Берёт за руку.'

    sister 'Андрей. Я знаю. Я знаю про неё.'
    main_bro 'Про кого?'
    sister 'Про ту, кого здесь нет. Про твою... тень.'

    'Сердце пропускает удар. Два. Три.'

    sister 'Я видела, как ты шепчешь что-то в углу.'
    sister 'Видела, как ты смотришь в отражение и улыбаешься.'
    sister 'Не мне. Ей.'

    main_bro 'Тебе показалось.'
    sister 'Мне никто не показывает. Я вижу.'
    sister 'Потому что я такая же. У меня тоже есть тот, кого нет.'

    'Она замолкает. Пауза. Тишина.'
    main_bro 'Кто?'
    sister 'Наша мама. Иногда я с ней разговариваю.'
    sister 'Просто сижу и говорю. А она молчит.'
    sister 'Но кажется, что слышит.'

    # ВЫБОР — ПРИЗНАТЬСЯ ПОЛНОСТЬЮ ИЛИ ОСТАВИТЬ В ТАЙНЕ
    menu:
        'Рассказать сестре про Милану.':
            $ helped_sister = True
            $ apathy -= 1
            main_bro 'Её зовут Милана.'
            sister 'Кто она?'
            main_bro 'Та, которую я... отпустил.'
            main_bro 'Та, которую выгнал на холод. А она хотела только обнять.'
            sister 'Ты её любил?'
            main_bro 'Не знаю. Теперь уже не важно.'
        
        'Промолчать. Уйти в темноту.':
            $ apathy += 2
            main_bro 'Нам пора спать. Завтра трудный день.'
            'Встаю. Ухожу в комнату. Не оборачиваюсь.'
            sister 'Андрей...'
            main_bro 'Спокойной ночи, Ангел.'

    jump chapter3_climax