
label chapter3_game_presentation:

    scene presentation_hall_dark
    'Главный офис. Большой зал. Десять пар глаз смотрят на меня.'
    main_bro 'Окна во всю стену. Свет — белый. Больничный.'
    main_bro 'Хочется зажмуриться. Исчезнуть. Раствориться.'

    curator 'Начинайте, [viname]. У вас десять минут.'

    'Я выхожу к трибуне. Руки трясутся. На лбу — холодный пот.'

    if embrace_alter:
        'Внутри — тишина. А потом я слышу её голос.'
        alter 'Не бойся. Просто повторяй за мной.'
        alter 'Я знаю, что говорить. Я знаю, что им нужно.'
        main_bro 'Ты — моя речь?'
        alter 'Я — твоя уверенность. Или то, что осталось от неё.'
    else:
        'Я один. Мои заметки — смятые, с плохим почерком.'
        main_bro 'У меня нет плана. Только страх. И пустота.'
        main_bro 'Главное — не замолчать. Главное — говорить.'

    # ВЫЗОВ МИНИ-ИГРЫ (логика — в отдельном файле)
    call minigame_presentation_engine

    # РЕЗУЛЬТАТ (получаем из переменных, которые установила мини-игра)
    if presentation_result == "win":
        'Последнее слово. Тишина. А потом — аплодисменты.'
        main_bro 'Я сделал это... Чёрт. Я правда сделал.'
        if embrace_alter:
            alter 'Мы сделали это. Я же говорила.'
        else:
            main_bro 'Сам. Без неё.'
        $ work_points += 10
        $ apathy -= 2
    elif presentation_result == "partial":
        'Аплодисменты вежливые. Кто-то смотрит в телефон.'
        curator 'Неплохо. Для первого раза.'
        main_bro 'Не провал. Но и не успех.'
        $ work_points += 3
    else:
        'Я замолкаю. Слова кончились.'
        'Кто-то кашляет. Кто-то шепчется.'
        curator 'Мы перезвоним.'
        main_bro 'Я провалился.'
        $ apathy += 4

    jump chapter3_home_sister_waiting