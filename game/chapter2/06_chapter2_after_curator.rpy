

label chapter2_after_curator:

    scene open_space_dark
    'Офис к вечеру. Окна темнеют. Люди уходят.'

    main_bro 'Я сижу за столом. Смотрю в одну точку. За окном — серое небо.'
    main_bro 'Макс подходит. Кладёт руку на плечо. Тяжёлую. Свою.'

    friend_max 'Ну как ты?'
    main_bro 'Не знаю.'
    friend_max 'Куратор ушёл довольный. Говорят, ты справился.'
    main_bro 'Говорят? Кто?'
    friend_max 'Начальник. Он сиял, как начищенный чайник.'

    'Я не чувствую радости. Только пустоту.'
    main_bro 'Справился. И что дальше?'
    friend_max 'Дальше — работа. Она никуда не делась.'

    'Кристина подходит. Молча протягивает сигарету.'
    main_bro 'Не надо...'
    kristina 'Надо. Идём.'

    # ВЫБОР — курить или нет
    menu:
        'Пойти на лестницу. Подышать дымом.':
            $ apathy -= 1
            $ trust_kristina += 1
            
            scene staircase_dark
            'Лестница. Холодно. Вода капает где-то сверху.'
            'Закуриваю. Кристина рядом. Молчит. Хорошая она.'
            'Не говорит глупостей. Не спрашивает «как дела».'
            'Просто стоит рядом. Дышит. Курит.'
            main_bro 'Спасибо тебе...'
            kristina 'За что?'
            main_bro 'За тишину.'
            
        'Остаться за столом. Смотреть в стену.':
            $ apathy += 2
            main_bro 'В другой раз.'
            'Кристина уходит. Её шаги затихают.'
            main_bro 'Я остаюсь один. Снова. Как всегда.'

    jump chapter2_office_sergy_alice