# ==================== ГЛАВА 4: ФИНАЛ ====================

label chapter4_ending:

    scene black
    
    # ========== КОНЦОВКА 1: ПРИНЯТИЕ (embraced_alter = True, apathy <= 3) ==========
    if embraced_alter and apathy <= 3:
        scene bus_stop_dawn_snow
        'Рассвет. Снег перестал. Я стою на остановке один.'
        
        main_bro 'Она ушла. Но не исчезла.'
        main_bro 'Я чувствую её тепло на щеке. Или это просто ветер?'
        
        'Телефон вибрирует снова. Сестра. Я беру трубку.'
        
        sister 'Андрей, ты где? Я волнуюсь.'
        main_bro 'На остановке.'
        sister 'Возвращайся. Я согрею чай.'
        main_bro 'Иду.'
        
        'Я иду домой. Не быстро. Не медленно. Просто иду.'
        main_bro 'Внутри — не пустота. Тишина. Спокойная.'
        main_bro 'Боль никуда не делась. Но она стала... моей.'
        main_bro 'Я принял её. И себя. Немного.'
        
        'Сестра встречает у двери. Обнимает. Молчит.'
        main_bro 'Всё будет хорошо?'
        sister 'Не знаю. Но мы будем вместе. Это точно.'
        
        scene black
        $ flash_text('КОНЦОВКА: ПРИНЯТИЕ', 2.0, 50)
        'Спасибо за игру.'
        return
    
    # ========== КОНЦОВКА 2: СЛИЯНИЕ (embraced_alter = True, apathy >= 4) ==========
    elif embraced_alter and apathy >= 4:
        scene bus_stop_void_snow
        'Я всё ещё держу её в объятиях.'
        'Автобус не приходит. Город исчезает. Только мы двое.'
        
        alter 'Ты принял меня. Полностью. Без остатка.'
        main_bro 'Что теперь?'
        alter 'Ничего. Только покой. Ни боли. Ни мыслей. Ни снов.'
        
        'Снег перестаёт. Мир замирает.'
        main_bro 'А сестра?'
        alter 'Она справится. У неё есть свой голос. Своя тень.'
        main_bro 'А я?'
        alter 'Ты теперь — это я. А я — это ты.'
        
        'Я закрываю глаза. Открывать не хочется.'
        main_bro 'Может, это и есть счастье? Просто исчезнуть.'
        alter 'Возможно. Спи, Андрей.'
        
        scene black
        $ flash_text('КОНЦОВКА: СЛИЯНИЕ', 2.0, 50)
        'Спасибо за игру.'
        return
    
    # ========== КОНЦОВКА 3: ОДИНОЧЕСТВО (embraced_alter = False, apathy <= 5) ==========
    elif not embraced_alter and apathy <= 5:
        scene bus_stop_morning_gray
        'Рассвет. Серый. Холодный.'
        main_bro 'Я один. Она исчезла. Сказала «прощай» и ушла.'
        
        'Телефон разряжен. Домой идти не хочется.'
        'Сажусь на скамейку. Смотрю на дорогу.'
        
        main_bro 'Может, я совершил ошибку? Может, надо было остаться с ней?'
        main_bro 'Но внутри — тихо. Не пусто. Просто тихо.'
        
        'Через час приезжает сестра на такси. Выскакивает, бежит ко мне.'
        
        sister 'Ты дурак! Я обыскалась!'
        main_bro 'Прости.'
        sister 'Садись в машину. Замёрзнешь.'
        
        'Еду домой. Молчу. Она молчит.'
        main_bro 'Ангел...'
        sister 'Что?'
        main_bro 'Спасибо, что не бросила.'
        sister 'Не за что. Мы же семья.'
        
        scene black
        $ flash_text('КОНЦОВКА: ОДИНОЧЕСТВО', 2.0, 50)
        'Спасибо за игру.'
        return
    
    # ========== КОНЦОВКА 4: РАСПАД (embraced_alter = False, apathy >= 6) ==========
    elif not embraced_alter and apathy >= 6:
        scene bus_stop_abandoned
        'Я сижу на остановке. Снег идёт, не переставая.'
        main_bro 'Она ушла. Я остался. Один.'
        main_bro 'Внутри — пустота. Такая огромная, что нечем дышать.'
        
        'Телефон разряжен. Идти некуда. Не хочется.'
        
        alter 'Ты прогнал меня. Теперь ты один.'
        main_bro 'Я знаю.'
        alter 'Что будешь делать?'
        main_bro 'Не знаю. Просто сидеть.'
        
        'Проходит час. Два. Сестра не ищет. Наверное, обиделась.'
        main_bro 'Может, так и надо? Просто сидеть. Ждать.'
        main_bro 'Чего? Автобуса. Который никогда не придёт.'
        
        'Я закрываю глаза. Снег укрывает меня, как одеяло.'
        main_bro 'Тихо. Спокойно. Наконец-то.'
        
        scene black
        $ flash_text('КОНЦОВКА: РАСПАД', 2.0, 50)
        'Спасибо за игру.'
        return
    
    # ========== КОНЦОВКА 5: ПО УМОЛЧАНИЮ (если что-то пошло не так) ==========
    else:
        scene home_night_final
        'Я возвращаюсь домой. Сестра спит на диване.'
        'Сажусь в кресло. Смотрю в потолок.'
        
        main_bro 'Милана... Она не пришла. Или я её не позвал.'
        main_bro 'Не знаю. Устал думать.'
        
        'Сон приходит медленно. Тяжёлый. Без снов.'
        
        sister 'Андрей... Ты здесь?'
        main_bro 'Здесь. Я всегда здесь.'
        sister 'Это хорошо. Спокойной ночи.'
        main_bro 'Спокойной ночи, Ангел.'
        
        scene black
        $ flash_text('КОНЦОВКА: ПРОДОЛЖЕНИЕ', 2.0, 50)
        'Конец. Но жизнь продолжается.'
        'Спасибо за игру.'
        return